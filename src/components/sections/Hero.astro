---
import Button from "../Button.astro";

const data = {
    name: "Redacks",
    description:
        "I care about software that’s useful, open, and genuinely helpful.",
    cta: [
        { label: "See Projects", href: "#PROJECTS", variant: "primary" },
        { label: "Contact Me", href: "#CONTACT", variant: "secondary" },
    ],
    scrollHint: "SCROLL",
} as const;
---

<section
    class="relative flex min-h-dvh flex-col items-center justify-center overflow-hidden px-8 pt-20 text-center"
    id="HOME"
>
    <div
        class="pointer-events-none absolute left-1/2 top-1/2 h-150 w-150 -translate-x-1/2 -translate-y-1/2 rounded-full bg-primary/10 blur-[120px]"
    >
    </div>
    <div class="z-10 max-w-4xl">
        <h1
            class="mb-6 font-h1 text-7xl leading-none tracking-[-0.02em] text-white md:text-9xl [text-shadow:0_0_30px_rgba(255,0,60,0.4)]"
        >
            {data.name}
        </h1>
        <h2 class="mb-12 font-h3 text-3xl tracking-[0.03em] text-white/40">
            {data.description}
        </h2>
        <div class="mt-12 flex justify-center gap-6">
            {
                data.cta.map((cta) => (
                    <Button href={cta.href} variant={cta.variant}>
                        {cta.label}
                    </Button>
                ))
            }
        </div>
    </div>
    <div
        class="absolute bottom-12 left-1/2 flex -translate-x-1/2 flex-col items-center gap-2 opacity-30"
    >
        <span class="font-label-caps text-xs tracking-widest"
            >{data.scrollHint}</span
        >
        <div class="h-12 w-px bg-linear-to-b from-white to-transparent"></div>
    </div>
</section>
