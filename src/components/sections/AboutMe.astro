---
import { Icon } from "astro-icon/components";
import SectionTitle from "../SectionTitle.astro";
import Card from "../Card.astro";

const iconMap: Record<string, string> = {
    wrench: "lucide:wrench",
    code: "lucide:code-2",
    sparkles: "lucide:sparkles",
};

const data = {
    heading: "About me",
    lead: "I am a student who loves building software and exploring technology.",
    cards: [
        {
            icon: "wrench",
            title: "Practical software",
            description:
                "I focus on tools and features that solve real problems.",
        },
        {
            icon: "code",
            title: "Build and improve",
            description: "I build to understand, then rebuild to do it better.",
        },
        {
            icon: "sparkles",
            title: "Continuous learning",
            description:
                "Each project helps me refine how I build and ship software.",
        },
    ],
};
---

<section class="mx-auto max-w-300 px-8 py-32" id="ABOUT">
    <SectionTitle heading={data.heading} />
    <div class="space-y-8">
        <Card hoverGlow={false}>
            <p class="font-h3 text-xl leading-[1.35] text-white md:text-2xl">
                {data.lead}
            </p>
        </Card>

        <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
            {
                data.cards.map((card) => (
                    <Card>
                        <div class="mb-5 text-primary">
                            <Icon
                                name={iconMap[card.icon] ?? "lucide:circle"}
                                class="h-7 w-7"
                            />
                        </div>
                        <h3 class="mb-2 font-h3 text-base leading-[1.3]">
                            {card.title}
                        </h3>
                        <p class="font-sans text-sm text-white/55">
                            {card.description}
                        </p>
                    </Card>
                ))
            }
        </div>
    </div>
</section>
