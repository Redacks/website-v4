---
import { Icon } from "astro-icon/components";
import SectionTitle from "../SectionTitle.astro";
import Card from "../Card.astro";
import Button from "../Button.astro";

const data = {
    heading: "Contact",
    lead: "Got an idea, a collaboration, or want to exchange about something? Reach out directly.",
    email: "hello@redacks.com",
    discord: "https://discord.com/users/redacks",
};
---

<section class="mx-auto max-w-300 px-8 py-32" id="CONTACT">
    <SectionTitle heading={data.heading} />

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
        <Card hoverGlow={false}>
            <div class="flex h-full flex-col p-2">
                <div class="grow">
                    <h3 class="mt-2 font-h3 text-2xl text-white">E-Mail</h3>
                    <p class="mt-4 text-white/60">
                        Best for formal inquiries, project proposals, and
                        detailed collaboration requests.
                    </p>
                </div>

                <div class="mt-8 flex flex-col">
                    <Button href={`mailto:${data.email}`} variant="primary">
                        <div class="flex items-center justify-center gap-2">
                            <Icon name="lucide:mail" class="size-5" />
                            <span class="font-h3 text-base md:text-lg"
                                >{data.email}</span
                            >
                        </div>
                    </Button>
                </div>

                <div class="mt-4 min-h-10">
                    <p class="text-[10px] leading-relaxed text-white/30 italic">
                        <strong>Privacy Note:</strong> Emails are processed via Google
                        LLC (USA) as an independent controller. Choosing this method
                        involves data transfer to the US. See my <a
                            href="/privacy"
                            class="underline hover:text-white/60"
                            >Privacy Policy</a
                        >.
                    </p>
                </div>
            </div>
        </Card>

        <Card hoverGlow={false}>
            <div class="flex h-full flex-col p-2">
                <div>
                    <h3 class="mt-2 font-h3 text-2xl text-white">Discord</h3>
                    <p class="mt-4 text-white/60">
                        Prefer a faster, more casual conversation? Feel free to
                        chat on my other socials.
                    </p>
                </div>

                <div class="mt-8 flex flex-col">
                    <Button variant="secondary">
                        <div class="flex items-center justify-center gap-2">
                            <Icon name="bi:discord" class="size-5" />
                            <span class="font-h3 text-base md:text-lg"
                                >@redacks</span
                            >
                        </div>
                    </Button>
                </div>
            </div>
        </Card>
    </div>
</section>
