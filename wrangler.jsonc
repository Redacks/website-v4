{
  "compatibility_date": "2026-04-28",
  "compatibility_flags": ["global_fetch_strictly_public"],
  "name": "redacks-website",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
  },
  "observability": {
    "enabled": true,
  },
  "routes": [
    {
      "pattern": "redacks.com",
      "custom_domain": true,
    },
  ],
  "workers_dev": false,
}
